############################################
# Build artifacts (CMake, MSVC, Ninja)
############################################
/build/
/out/
/cmake-build*/
/CMakeFiles/
/CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
Testing/

############################################
# CMake File API (used by Visual Studio)
############################################
.cmake/
*.json

############################################
# Visual Studio generated files
############################################
.vs/
*.VC.db
*.VC.db-shm
*.VC.db-wal
*.opendb
*.suo
*.user
*.userosscache
*.sln.docstates

# Ignore IDE-generated solution/project files
# (CMake will regenerate them)
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

############################################
# Visual Studio Code
############################################
.vscode/

############################################
# Python cache (if build scripts are used)
############################################
__pycache__/
*.pyc

############################################
# Temporary / backup files
############################################
*.tmp
*.log
*.bak
*.swp
*.swo

############################################
# OS-specific junk files
############################################
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride
